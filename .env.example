# MySQL (XAMPP default)

DB_HOST=127.0.0.1

DB_PORT=3306

DB_USER=root

DB_PASSWORD=

DB_NAME=couponspeak_crawl

# Web local — để trống = tự detect (scan.test hoặc localhost/scan/web)
WEB_BASE_PATH=

# Crawler

BASE_URL=https://couponspeak.com

REQUEST_DELAY=0.8

MAX_CONCURRENT=3

REQUEST_TIMEOUT=30

SAVE_RAW_HTML=0



# Lịch crawl

# CRAWL_INTERVAL_DAYS: số ngày giữa 2 lần chạy daily_crawl (1 = mỗi ngày)

CRAWL_INTERVAL_DAYS=1

# INCREMENTAL_STALE_DAYS: store chưa crawl trong N ngày sẽ được re-check

INCREMENTAL_STALE_DAYS=1

# FULL_CRAWL_INTERVAL_DAYS: mỗi N ngày chạy search discovery tìm store mới

FULL_CRAWL_INTERVAL_DAYS=7

INCREMENTAL_TIER3_BATCH=200

SEARCH_MAX_PAGES=50

# Gemini — ưu tiên khi GEMINI_ENABLED=true (GET /api/coupons fallback)
GEMINI_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=90
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# OpenAI-compatible fallback (khi GEMINI_ENABLED=false)
API_AI=https://api.openai.com/v1/chat/completions
API_AI_KEY=
API_AI_MODEL=gpt-4o-mini
API_AI_ENABLED=1
API_AI_MAX_OFFERS=10
# false = tắt AI fallback khi GET /api/coupons trả count: 0
API_AI_FALLBACK_ENABLED=true
AFFILIATE_PARAM=sca_ref=10362718
AFFILIATE_BASE_URL=

# Python job jobs/ai_fetch_store_offers.py (tùy chọn)
WEB_BASE_URL=http://scan.test
API_SITE=thuoc360

# Hako DB — dùng khi chạy jobs/import_affiliate_watch_stores.php
HAKO_DB_HOST=127.0.0.1
HAKO_DB_PORT=3306
HAKO_DB_NAME=hakoreview
HAKO_DB_USER=root
HAKO_DB_PASSWORD=
